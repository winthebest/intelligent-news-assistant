# Copy to `.env` and fill in. `.env` is gitignored.
# ---------------------------------------------------------------------------

# --- Crawler ---------------------------------------------------------------
SELENIUM_HEADLESS=true
CRAWL_DELAY=1.5
REQUEST_TIMEOUT=30

# VnExpress section to crawl. Change both to swap topic (e.g. suc-khoe).
VNEXPRESS_BASE_URL=https://vnexpress.net/khoa-hoc-cong-nghe
VNEXPRESS_CATEGORY=khoa-hoc-cong-nghe

# --- LLM (Phase 3) ---------------------------------------------------------
# Pick ONE of the two lines below. Default = Gemini (quality, paid).
LLM_MODEL=gemini/gemini-1.5-flash
# LLM_MODEL=ollama/qwen2.5:14b-instruct    # recommended if GPU >=10GB VRAM
# LLM_MODEL=ollama/qwen2.5:7b-instruct     # ok for 6-8GB VRAM boxes

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
LLM_CACHE_ENABLED=true

# Provider credentials. Only the one matching LLM_MODEL is used.
GEMINI_API_KEY=your-gemini-key-here
OLLAMA_API_BASE=http://localhost:11434

# --- Ollama tuning ---------------------------------------------------------
# CRITICAL: Ollama's default context is 2048 tokens, which silently truncates
# our NER prompt (~3k tokens). 8192 is safe for the current 61-article corpus
# with headroom; raise to 16384 if you scale to >200 articles.
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=2048
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40
OLLAMA_REPEAT_PENALTY=1.05

# Preflight warning triggers when a prompt exceeds this fraction of num_ctx.
PREFLIGHT_CTX_RATIO=0.9
PREFLIGHT_CHARS_PER_TOKEN=2.5

# --- Keyword extraction ----------------------------------------------------
KEYWORD_TOP_K=15
TFIDF_MIN_DF=3
TFIDF_MAX_DF=0.6
# Bigrams/trigrams only: Vietnamese compound words need ≥2 syllables.
TFIDF_NGRAM_MIN=2
TFIDF_NGRAM_MAX=3
NER_MIN_ARTICLE_COUNT=2

# Path to a Vietnamese stopwords file (one word/phrase per line). Default
# points to the community ~1.9k-entry list bundled in resources/. Change if
# you curate a topic-specific list.
STOPWORDS_FILE=resources/vietnamese-stopwords.txt

# --- Reporter (Phase 4) ----------------------------------------------------
# How many articles to surface in "Highlighted News" and how many keywords
# to list in the "Trending Keywords" table.
REPORT_TOP_ARTICLES=5
REPORT_TOP_KEYWORDS=10
# Per-day geometric decay for recency (0 = ignore age, 0.08 halves at ~9d).
REPORT_RECENCY_DECAY=0.08
# Diversity: skip candidate if it overlaps this many keywords with a pick.
REPORT_DIVERSITY_MAX_OVERLAP=3
# Toggle the LLM-generated Executive Summary. When false (or when the call
# fails) a deterministic template paragraph is used instead.
REPORT_USE_LLM_SUMMARY=true
